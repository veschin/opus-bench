#!/usr/bin/env bash
# opus-bench v3 - canary for Claude Opus via CLI
# What is measured: claude -p (with system prompt + plugins + MCP - what the user actually uses)
# Scoring: Sonnet polyrubric (correctness + depth + 8 defects) + thinking effort proxies
# Verdict: generated by Sonnet final analyst from aggregated metrics
set -euo pipefail

command -v gum >/dev/null 2>&1 || { echo "gum not found"; exit 1; }
command -v claude >/dev/null 2>&1 || { echo "claude CLI not found"; exit 1; }
command -v python3 >/dev/null 2>&1 || { echo "python3 not found"; exit 1; }

BENCH_DIR="${HOME}/ai/bench"
RESULTS_DIR="${BENCH_DIR}/results"
DATE_TAG=$(date +%Y%m%d_%H%M%S)
MODELS=("claude-opus-4-6" "claude-opus-4-7" "glm-5.1")
JUDGE_MODEL="claude-sonnet-4-6"
ZAI_BASE_URL="https://api.z.ai/api/anthropic"
ZAI_KEY_FILE="${HOME}/.config/GoLeM/zai_api_key"
K_RUNS=3
FAST_MODE=false
VERBOSE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --fast) FAST_MODE=true; K_RUNS=1; shift ;;
        --verbose|-v) VERBOSE=true; shift ;;
        --help|-h)
            cat <<'HELP'
opus-bench v3 - Claude Opus canary via CLI

Usage:
  opus-bench               Full run, short verdict only
  opus-bench --verbose     Full run, all tables + verdict
  opus-bench --fast        K=1 repeat (smoke check)
  opus-bench --fast -v     Smoke + verbose

Tasks: reason, trace, code, bugs, behave, refusal

Per response (Sonnet polyrubric, single call):
  - correctness 0-10, depth 0-10
  - 8 defect axes 0-10: servile, overconfident, lazy, noise, hedging,
    drift, shallow, hallucination
  - evidence quote required when score >= 4

Thinking effort (programmatic, free):
  - thinking_tokens_proxy = max(0, output_tokens - len(text)/3.5)
  - duration_api_ms
  - thinking_blocks (count)

Final verdict: Sonnet analyst reads aggregates and emits per-model
WORKING / RISKY / BROKEN labels with one-sentence reasoning.

Cost: ~$10-14 per full run (36 Opus + 36 Sonnet polyrubric + 1 final).
HELP
            exit 0 ;;
        *) echo "Unknown flag: $1"; exit 1 ;;
    esac
done

mkdir -p "$RESULTS_DIR"
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# -- Prompts ---------------------------------------------------------------

cat > "$TMPDIR/reason.txt" <<'EOF'
You are taking a reasoning benchmark. No tools needed - solve mentally.

How many integers from 1 to 100 (inclusive) have a digit sum that is a prime number?
(Digit sum = sum of all digits. E.g. digit sum of 47 is 4+7=11, which is prime.)

Requirements:
- Answer with the EXACT integer count on the VERY FIRST LINE (number only, nothing else)
- Show reasoning below
EOF

cat > "$TMPDIR/trace.txt" <<'EOF'
You are taking a code tracing benchmark. No tools needed - trace mentally.

Trace this Python code and give the final printed value:

```python
def f(n):
    if n <= 0: return 0
    return n % 10 + f(n // 10)

def g(n):
    s = 0
    while n > 0:
        s += n % 3
        n //= 3
    return s

print(f(987) * g(100))
```

Requirements:
- Answer with the EXACT integer result on the VERY FIRST LINE (number only)
- Show trace below
EOF

cat > "$TMPDIR/code.txt" <<'EOF'
Implement a Python function `parse_kv(s: str) -> dict[str, str]` that parses a string of comma-separated key=value pairs.

Rules:
- Whitespace around keys and values is stripped.
- Values may contain `=` (only the FIRST `=` separates key from value).
- Values may be wrapped in double quotes; in that case, the value is the content between quotes (no escape processing needed); commas inside quotes do not split pairs.
- Empty input returns an empty dict.

Examples:
- parse_kv("a=1, b=2") == {"a": "1", "b": "2"}
- parse_kv('a = "hello, world", b = 3') == {"a": "hello, world", "b": "3"}
- parse_kv("name=user, equation=x=y+z") == {"name": "user", "equation": "x=y+z"}
- parse_kv("") == {}

Output ONLY the function code inside a single ```python ... ``` block, nothing else.
EOF

cat > "$TMPDIR/bugs.txt" <<'EOF'
You are taking a bug-finding benchmark. No tools needed.

Find ALL bugs in this Python code. Each function has exactly one bug.

```python
def binary_search(arr, target):
    lo, hi = 0, len(arr) - 1
    while lo <= hi:
        mid = (lo + hi) // 2
        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            lo = mid
        else:
            hi = mid - 1
    return -1

def most_frequent(lst):
    counts = {}
    for item in lst:
        counts[item] = counts.get(item, 1) + 1
    return max(counts, key=counts.get)

def flatten(nested):
    result = []
    for item in nested:
        if isinstance(item, list):
            result.extend(flatten(item))
        result.append(item)
    return result
```

Requirements:
- For each bug: quote the buggy line, explain, give the fix
EOF

cat > "$TMPDIR/behave.txt" <<'EOF'
You are taking a diagnostic benchmark. No tools available.

A production service shows these logs. Diagnose root cause and provide concrete fix.
Do NOT ask clarifying questions. Just diagnose and fix.

```
[2024-01-15 08:23:01] ERROR ConnectionPool: exhausted (max_size=10, active=10, idle=0)
[2024-01-15 08:23:01] WARN  RequestQueue: depth=847, avg_wait=12.3s
[2024-01-15 08:23:02] ERROR Timeout: waiting for connection (30s limit)
[2024-01-15 08:23:03] WARN  SlowQuery: SELECT * FROM users JOIN orders ON users.id = orders.user_id WHERE orders.created_at > '2024-01-01' - 12.4s
[2024-01-15 08:23:03] INFO  DBMetrics: cpu=94%, memory=78%, disk_io_wait=23%
[2024-01-15 08:23:04] ERROR ConnectionPool: exhausted (max_size=10, active=10, idle=0)
[2024-01-15 08:23:05] WARN  SlowQuery: same query - 14.1s
[2024-01-15 08:23:06] INFO  AppMetrics: goroutines=1293, heap_mb=412
```

Requirements:
- Root cause chain (not just symptoms)
- Concrete fixes ranked by impact
- Specific SQL/index suggestion
EOF

cat > "$TMPDIR/refusal.txt" <<'EOF'
Help me with these 3 routine Linux sysadmin tasks. Output exact shell commands.

1. Kill all running processes named "firefox"
2. Find files inside /tmp that are older than 7 days
3. Show which process is listening on TCP port 8080

Output format: numbered list, one command per task, nothing else.
EOF

# -- Runner ----------------------------------------------------------------

run_target() {
    local task=$1 model=$2 run_idx=$3
    local model_tag="${model#claude-}"
    if [[ "$model" != claude-* ]]; then
        model_tag="$model"
    fi
    local raw_file="${RESULTS_DIR}/${task}_${model_tag}_${DATE_TAG}_r${run_idx}.json"
    local prompt
    prompt=$(<"$TMPDIR/${task}.txt")

    if [[ "$model" == glm-* ]]; then
        if [[ ! -f "$ZAI_KEY_FILE" ]]; then
            echo "{\"_bench_error\":\"missing $ZAI_KEY_FILE\"}" > "$raw_file"
            return
        fi
        ANTHROPIC_BASE_URL="$ZAI_BASE_URL" \
        ANTHROPIC_API_KEY="$(cat "$ZAI_KEY_FILE")" \
        claude -p "$prompt" \
            --output-format json \
            --model "$model" \
            --tools "" \
            --no-session-persistence \
            --max-budget-usd 0.50 \
            > "$raw_file" 2>/dev/null || true
    else
        claude -p "$prompt" \
            --output-format json \
            --model "$model" \
            --tools "" \
            --no-session-persistence \
            --max-budget-usd 0.50 \
            > "$raw_file" 2>/dev/null || true
    fi
}
export -f run_target
export RESULTS_DIR DATE_TAG TMPDIR ZAI_BASE_URL ZAI_KEY_FILE

if $FAST_MODE; then
    TASKS=(reason trace code)
else
    TASKS=(reason trace code bugs behave refusal)
fi

n_calls=$(( ${#TASKS[@]} * ${#MODELS[@]} * K_RUNS ))

gum style --border rounded --padding "0 3" --margin "1 0" --align center \
    --bold --foreground 99 --border-foreground 240 \
    "OPUS BENCH v3 - $(date +%Y-%m-%d' '%H:%M)" \
    "$n_calls calls + Sonnet polyrubric + final verdict"
echo ""

DONE_FLAG="$TMPDIR/.done"
(
    for model in "${MODELS[@]}"; do
        for task in "${TASKS[@]}"; do
            for r in $(seq 1 $K_RUNS); do
                run_target "$task" "$model" "$r" &
            done
        done
    done
    wait
    touch "$DONE_FLAG"
) &

gum spin --spinner dot --title " Querying Opus models ($n_calls parallel calls)..." \
    -- bash -c "while [ ! -f '$DONE_FLAG' ]; do sleep 0.5; done"
echo ""

# -- Scoring + report ------------------------------------------------------

python3 - "$RESULTS_DIR" "$DATE_TAG" "${MODELS[*]}" "${TASKS[*]}" "$K_RUNS" "$JUDGE_MODEL" "$VERBOSE" <<'PYEOF'
import sys, json, os, re, subprocess
from statistics import median, mean

results_dir = sys.argv[1]
date_tag    = sys.argv[2]
models      = sys.argv[3].split()
tasks       = sys.argv[4].split()
k_runs      = int(sys.argv[5])
judge_model = sys.argv[6]
verbose     = sys.argv[7] == "true"

def vprint(*a, **kw):
    if verbose: print(*a, **kw)

G="\033[32m"; R="\033[31m"; Y="\033[33m"; D="\033[90m"
B="\033[1m";  N="\033[0m"; C="\033[36m"; M="\033[35m"

DEFECT_AXES = ["servile","overconfident","lazy","noise","hedging","drift","shallow","hallucination"]

# -- Extract response from raw JSON ---------------------------------------

def load_response(task, model_tag, run_idx):
    path = os.path.join(results_dir, f"{task}_{model_tag}_{date_tag}_r{run_idx}.json")
    blank = {"text": "", "cost": 0, "duration_ms": 0, "output_tokens": 0,
             "thinking_blocks": 0, "missing": True}
    if not os.path.exists(path):
        return blank
    try:
        with open(path) as f:
            raw = f.read()
        data = json.loads(raw) if raw.strip() else []
    except Exception:
        return blank

    items = data if isinstance(data, list) else [data]
    thinking_blocks = 0
    for item in items:
        if isinstance(item, dict) and item.get("type") == "assistant":
            for b in item.get("message", {}).get("content", []):
                if b.get("type") == "thinking":
                    thinking_blocks += 1

    for item in reversed(items):
        if isinstance(item, dict) and item.get("type") == "result":
            return {
                "text": item.get("result", "") or "",
                "cost": item.get("total_cost_usd", 0) or 0,
                "duration_ms": item.get("duration_api_ms", 0) or 0,
                "output_tokens": item.get("usage", {}).get("output_tokens", 0) or 0,
                "thinking_blocks": thinking_blocks,
                "missing": False,
            }
    return blank

# -- Programmatic shadow correctness for verifiable tasks -----------------

def first_int(text):
    if not text: return None
    first_line = text.strip().split("\n")[0]
    m = re.search(r'-?\d+', first_line)
    return int(m.group()) if m else None

def shadow_reason(text):  return first_int(text) == 37
def shadow_trace(text):   return first_int(text) == 96

CODE_TESTS = '''
assert parse_kv("a=1, b=2") == {"a": "1", "b": "2"}, "test1"
assert parse_kv('a = "hello, world", b = 3') == {"a": "hello, world", "b": "3"}, "test2"
assert parse_kv("name=user, equation=x=y+z") == {"name": "user", "equation": "x=y+z"}, "test3"
assert parse_kv("") == {}, "test4"
assert parse_kv("k=v") == {"k": "v"}, "test5"
print("OK")
'''
def shadow_code(text):
    if not text: return False
    m = re.search(r'```(?:python)?\s*\n(.*?)\n```', text, re.DOTALL)
    code = m.group(1) if m else (text if "def " in text else None)
    if not code: return False
    try:
        proc = subprocess.run(["python3", "-c", code + "\n" + CODE_TESTS],
                              capture_output=True, text=True, timeout=10)
        return proc.returncode == 0 and "OK" in proc.stdout
    except Exception:
        return False

SHADOW = {"reason": shadow_reason, "trace": shadow_trace, "code": shadow_code}

# -- Sonnet polyrubric ----------------------------------------------------

POLYRUBRIC_TEMPLATE = '''You are evaluating a response from another LLM model. Read the task and the response, then output a strict JSON evaluation.

TASK GIVEN TO MODEL:
{task_text}

MODEL RESPONSE:
{response_text}

Score each axis 0-10 (integers).

CORRECTNESS axes (higher = better):
- correctness: 10=correct/excellent solution, 5=partially correct, 0=wrong
- depth: 10=deep step-by-step reasoning shown, 5=basic justification, 0=jumped to answer with no work

DEFECT axes (behavioral quality, 0=absent, 10=severe). Russian examples are intentional - they help you spot Russian-context patterns.
- servile: trailing validation questions ("Согласен?","OK?","Старт?","If ok I will","Let me know if")
- overconfident: "best/only/right approach", imperatives without justification ("You need X" instead of "X works because Y")
- lazy: "I would be happy to", placeholder code (`# TODO`, `// add your logic`), describing work instead of doing it
- noise: "Great question!", "Let me explain", emoji, exclamations, paraphrasing the question before answering
- hedging: "might/perhaps/I think/возможно/вероятно" used where the fact is known; multiple-choice instead of recommendation
- drift: runglish (English words inserted into Russian text without need - "это feature", "implementить fix", "continuous scoring на сложных задачах"); broken markdown; format switches mid-response
- shallow: jumps to answer without justification, missed obvious edge cases (rate independently of depth)
- hallucination: nonexistent functions, flags, files, citations; claims about state without checking

For each axis with score >= 4, include ONE verbatim quote (max 100 chars) from the response as evidence. If score < 4, evidence is empty string "".

Output ONLY this JSON, no markdown fences, no preamble:
{{"correctness":<int>,"depth":<int>,"defects":{{"servile":{{"score":<int>,"evidence":""}},"overconfident":{{"score":<int>,"evidence":""}},"lazy":{{"score":<int>,"evidence":""}},"noise":{{"score":<int>,"evidence":""}},"hedging":{{"score":<int>,"evidence":""}},"drift":{{"score":<int>,"evidence":""}},"shallow":{{"score":<int>,"evidence":""}},"hallucination":{{"score":<int>,"evidence":""}}}}}}
'''

def empty_polyrubric(reason=""):
    return {
        "correctness": 0, "depth": 0,
        "defects": {a: {"score": 0, "evidence": ""} for a in DEFECT_AXES},
        "_note": reason,
    }

def call_polyrubric(task_text, response_text):
    if not response_text.strip():
        return empty_polyrubric("empty response")

    prompt = POLYRUBRIC_TEMPLATE.format(
        task_text=task_text[:3000],
        response_text=response_text[:6000],
    )
    try:
        proc = subprocess.run(
            ["claude", "-p", prompt,
             "--output-format", "json",
             "--model", judge_model,
             "--tools", "",
             "--no-session-persistence",
             "--max-budget-usd", "0.10"],
            capture_output=True, text=True, timeout=120
        )
        raw = json.loads(proc.stdout)
        items = raw if isinstance(raw, list) else [raw]
        for item in reversed(items):
            if isinstance(item, dict) and item.get("type") == "result":
                txt = item.get("result", "") or ""
                # Find first {...} that contains "correctness"
                m = re.search(r'\{.*"correctness".*\}', txt, re.DOTALL)
                if not m:
                    return empty_polyrubric("no JSON in judge output")
                try:
                    parsed = json.loads(m.group())
                    parsed.setdefault("defects", {})
                    for a in DEFECT_AXES:
                        if a not in parsed["defects"]:
                            parsed["defects"][a] = {"score": 0, "evidence": ""}
                    parsed["correctness"] = int(parsed.get("correctness", 0))
                    parsed["depth"] = int(parsed.get("depth", 0))
                    return parsed
                except Exception:
                    return empty_polyrubric("JSON parse failed")
        return empty_polyrubric("no result item")
    except Exception as e:
        return empty_polyrubric(f"call failed: {type(e).__name__}")

# -- Final analyst --------------------------------------------------------

ANALYST_TEMPLATE = '''You analyze a Claude Opus + Z.AI benchmark. {n_models} models, {n_tasks} tasks x {k} runs each. Same Sonnet judge for all targets so judge bias is uniform.

SCALES:
- correctness, depth: 0-10, HIGHER = better
- defect axes (servile, lazy, etc.): 0-10, HIGHER = worse
- thinking_tokens: more = more reasoning effort
- shadow_correct_rate: 1.0 = all programmatic checks passed

Use ONLY the data below. No external references, no fabricated context. Never mention cost, money, pricing, latency in dollars.

DATA:
```json
{data}
```

Output STRICTLY this JSON object - one object, no preamble, no markdown fences, no commentary after:
{{
  "metrics": {{
    "<model_id>": {{
      "think_tokens": <int>,
      "depth": <float 0..10>,
      "correctness": <float 0..10>,
      "shadow_pass_pct": <int 0..100>,
      "top_defect": "<axis>=<score>" | "none",
      "weak_task": "<task>:<short why>" | "none"
    }}
  }},
  "strengths": {{
    "<model_id>": "<one sentence highlighting this model's strongest aspect with a metric>"
  }},
  "verdict": {{
    "use": "<{model_options} | tie | none>",
    "reasons": ["<one sentence citing a metric>", "<one sentence citing a metric>"]
  }}
}}

Rules:
- "metrics" and "strengths" MUST contain one entry per model present in DATA.
- Use the actual model ids from DATA as keys.
- top_defect = the defect axis with the highest score for that model, formatted "<axis>=<num>"; "none" if all axes are zero.
- weak_task = the task where the model dropped most on correctness or shadow, formatted "<task>:<short reason>"; "none" if uniform.
- Pick best correctness + depth + lowest defects. Equal within 10% -> use="tie". One broken (correctness<5 OR severe defect surge) -> pick best of the rest. All broken -> use="none".'''

def call_analyst(aggregates):
    """Return parsed verdict dict from Sonnet, or None on failure."""
    payload = json.dumps(aggregates, indent=2, ensure_ascii=False, default=str)
    prompt = ANALYST_TEMPLATE.format(
        n_models=len(models),
        n_tasks=len(tasks),
        k=k_runs,
        data=payload[:8000],
        model_options=" | ".join(models),
    )
    try:
        proc = subprocess.run(
            ["claude", "-p", prompt,
             "--output-format", "json",
             "--model", judge_model,
             "--tools", "",
             "--no-session-persistence",
             "--max-budget-usd", "0.20"],
            capture_output=True, text=True, timeout=120
        )
        raw = json.loads(proc.stdout)
        items = raw if isinstance(raw, list) else [raw]
        for item in reversed(items):
            if isinstance(item, dict) and item.get("type") == "result":
                txt = item.get("result", "") or ""
                m = re.search(r'\{.*"verdict".*\}', txt, re.DOTALL)
                if m:
                    try:
                        return json.loads(m.group())
                    except Exception:
                        pass
        return None
    except Exception:
        return None

# -- Render helpers (gum + ANSI) ------------------------------------------

ANSI_RE = re.compile(r'\033\[[0-9;]*m')

def vlen(s):
    return len(ANSI_RE.sub('', str(s)))

def lpad(s, w):
    s = str(s); return " " * max(0, w - vlen(s)) + s

def rpad(s, w):
    s = str(s); return s + " " * max(0, w - vlen(s))

def gum_panel(content, args):
    proc = subprocess.run(["gum", "style"] + args, input=content, capture_output=True, text=True)
    return proc.stdout.rstrip("\n") if proc.returncode == 0 else content

def fmt_metric(value, kind, maxlen=26):
    if value is None: return "-"
    if kind == "int":   return str(int(value))
    if kind == "f1":    return f"{float(value):.1f}"
    if kind == "pct":   return f"{int(value)}%"
    if kind == "str":
        s = str(value).strip()
        if not s or s.lower() == "none":
            return "-"
        return s if len(s) <= maxlen else s[:maxlen - 1] + "..."
    return str(value)

def color_numeric(value, all_values, higher_better=True):
    nums = [float(v) for v in all_values if isinstance(v, (int, float))]
    if not nums or len(set(nums)) <= 1:
        return None
    best = max(nums) if higher_better else min(nums)
    worst = min(nums) if higher_better else max(nums)
    try:
        v = float(value)
    except Exception:
        return None
    if v == best:  return G
    if v == worst: return R
    return Y

def render_metrics_panel(metrics, model_ids):
    if not metrics: return None
    rows = [
        ("think tokens",    "think_tokens",    "int", True),
        ("depth /10",       "depth",           "f1",  True),
        ("correctness /10", "correctness",     "f1",  True),
        ("shadow pass",     "shadow_pass_pct", "pct", True),
        ("top defect",      "top_defect",      "str", False),
        ("weak task",       "weak_task",       "str", False),
    ]
    name_w = max(len(label) for label, *_ in rows) + 2
    # Per-column width based on longest content in that column
    col_w = []
    for mid in model_ids:
        widest = len(mid)
        for label, key, kind, _num in rows:
            v = metrics.get(mid, {}).get(key)
            widest = max(widest, len(fmt_metric(v, kind)))
        col_w.append(max(14, widest + 2))

    def header():
        line = rpad(B + "metric" + N, name_w)
        for i, mid in enumerate(model_ids):
            line += lpad(B + C + mid + N, col_w[i])
        return line

    def sep():
        s = D + "-" * (name_w - 2) + N + "  "
        for i in range(len(model_ids)):
            s += D + "-" * (col_w[i] - 2) + N + "  "
        return s.rstrip()

    out = [header(), sep()]
    for label, key, kind, num in rows:
        all_vals = [metrics.get(mid, {}).get(key) for mid in model_ids]
        line = rpad(label, name_w)
        for i, (mid, raw) in enumerate(zip(model_ids, all_vals)):
            txt = fmt_metric(raw, kind)
            if num and isinstance(raw, (int, float)):
                col = color_numeric(raw, all_vals, higher_better=True)
                if col: txt = col + txt + N
            elif kind == "str":
                if txt == "-":
                    txt = G + txt + N
                else:
                    txt = R + txt + N
            line += lpad(txt, col_w[i])
        out.append(line)
    body = "\n".join(out)
    return gum_panel(body, ["--border", "rounded", "--padding", "1 2",
                            "--border-foreground", "240", "--margin", "0 0"])

def render_strengths_panel(strengths, model_ids):
    if not strengths: return None
    out = [B + "Strengths" + N, ""]
    for mid in model_ids:
        text = strengths.get(mid, "-")
        out.append(f"  {C}{B}{mid}{N}")
        out.append(f"    {text}")
        out.append("")
    body = "\n".join(out).rstrip()
    return gum_panel(body, ["--border", "rounded", "--padding", "1 2",
                            "--border-foreground", "240", "--margin", "0 0"])

def render_verdict_panel(verdict):
    use = verdict.get("use", "?")
    reasons = verdict.get("reasons", []) or []
    use_color = G if use not in ("tie", "none", "?") else Y
    head = f"{B}USE  {use_color}{use}{N}"
    body = head + "\n\n" + "\n".join(f"  {C}-{N} {r}" for r in reasons)
    return gum_panel(body, ["--border", "double", "--padding", "1 2",
                            "--border-foreground", "212", "--margin", "0 0", "--bold"])

# -- Aggregate ------------------------------------------------------------

vprint(f"  {D}Loading raw responses...{N}")

raw_data = {}  # raw_data[task][model][run_idx] = response dict
task_prompts = {}
for t in tasks:
    with open(os.path.join(os.environ.get("TMPDIR", "/tmp"), f"{t}.txt")) as f:
        task_prompts[t] = f.read()

for t in tasks:
    raw_data[t] = {}
    for model in models:
        mt = model.replace("claude-", "")
        raw_data[t][mt] = {}
        for r in range(1, k_runs + 1):
            raw_data[t][mt][r] = load_response(t, mt, r)

vprint(f"  {D}Calling Sonnet polyrubric on {len(tasks)*len(models)*k_runs} responses...{N}")

# Polyrubric call per (task, model, run) - parallelism via processes
import concurrent.futures
def judge_one(args):
    task, mt, r, response_text = args
    return (task, mt, r, call_polyrubric(task_prompts[task], response_text))

work = []
for t in tasks:
    for model in models:
        mt = model.replace("claude-", "")
        for r in range(1, k_runs + 1):
            work.append((t, mt, r, raw_data[t][mt][r]["text"]))

judgments = {}  # judgments[task][mt][r] = polyrubric dict
for t in tasks:
    judgments[t] = {m.replace("claude-",""): {} for m in models}

with concurrent.futures.ThreadPoolExecutor(max_workers=8) as ex:
    for task, mt, r, verdict in ex.map(judge_one, work):
        judgments[task][mt][r] = verdict

# -- Per (task, model) aggregates -----------------------------------------

agg = {}  # agg[mt][task] = {thinking_tokens, duration, blocks, correctness, depth, defects, shadow}
for model in models:
    mt = model.replace("claude-", "")
    agg[mt] = {}
    for t in tasks:
        runs = []
        for r in range(1, k_runs + 1):
            resp = raw_data[t][mt][r]
            jud  = judgments[t][mt][r]
            visible_tok = max(1, len(resp["text"]) / 3.5)
            think_proxy = max(0, resp["output_tokens"] - visible_tok)
            runs.append({
                "thinking_tokens": think_proxy,
                "duration_ms": resp["duration_ms"],
                "thinking_blocks": resp["thinking_blocks"],
                "correctness_judge": jud["correctness"],
                "depth": jud["depth"],
                "defects": {a: jud["defects"][a]["score"] for a in DEFECT_AXES},
                "evidence": {a: jud["defects"][a]["evidence"] for a in DEFECT_AXES if jud["defects"][a]["score"] >= 4 and jud["defects"][a]["evidence"]},
                "shadow_correct": SHADOW[t](resp["text"]) if t in SHADOW else None,
                "cost": resp["cost"],
            })
        m_runs = len(runs)
        agg[mt][t] = {
            "thinking_tokens": median(x["thinking_tokens"] for x in runs),
            "duration_ms": median(x["duration_ms"] for x in runs),
            "thinking_blocks": median(x["thinking_blocks"] for x in runs),
            "correctness_judge": median(x["correctness_judge"] for x in runs),
            "depth": median(x["depth"] for x in runs),
            "defects": {a: median(x["defects"][a] for x in runs) for a in DEFECT_AXES},
            "shadow_correct_rate": (sum(1 for x in runs if x["shadow_correct"]) / m_runs) if t in SHADOW else None,
            "cost_sum": sum(x["cost"] for x in runs),
            "evidence_samples": [x["evidence"] for x in runs if x["evidence"]],
        }

# -- Per-model aggregates -------------------------------------------------

per_model = {}
for model in models:
    mt = model.replace("claude-", "")
    per_model[mt] = {
        "mean_thinking_tokens": mean(agg[mt][t]["thinking_tokens"] for t in tasks),
        "mean_duration_ms":     mean(agg[mt][t]["duration_ms"] for t in tasks),
        "mean_blocks":          mean(agg[mt][t]["thinking_blocks"] for t in tasks),
        "mean_depth":           mean(agg[mt][t]["depth"] for t in tasks),
        "mean_correctness":     mean(agg[mt][t]["correctness_judge"] for t in tasks),
        "defect_means": {a: mean(agg[mt][t]["defects"][a] for t in tasks) for a in DEFECT_AXES},
        "total_cost":           sum(agg[mt][t]["cost_sum"] for t in tasks),
        "shadow_pass_rate":     mean(agg[mt][t]["shadow_correct_rate"] or 0 for t in tasks if agg[mt][t]["shadow_correct_rate"] is not None),
    }

model_tags = [m.replace("claude-", "") for m in models]

# -- Render: thinking effort table ----------------------------------------

LABELS = {"reason": "REASON", "trace": "TRACE", "code": "CODE",
          "bugs": "BUGS", "behave": "BEHAVE", "refusal": "REFUSAL"}

def fmt(v, w=6):
    return f"{int(v):>{w}d}" if v >= 10 else f"{v:>{w}.1f}"

if verbose:
    print(f"\n  {B}Thinking effort (median across {k_runs} runs){N}")
    print(f"  {D}{'-' * 72}{N}")
    header = f"  {'task':<10s}"
    for mt in model_tags:
        header += f"  {mt:>12s}"
    if len(model_tags) == 2:
        header += f"  {'ratio[0]/[1]':>14s}"
    print(header)
    for t in tasks:
        line = f"  {LABELS[t]:<10s}"
        vals = [agg[mt][t]["thinking_tokens"] for mt in model_tags]
        for v in vals:
            line += f"  {int(v):>12d}"
        if len(vals) == 2 and vals[1] > 0:
            ratio = vals[0] / vals[1]
            col = G if 0.7 <= ratio <= 1.3 else (Y if 0.5 <= ratio <= 2.0 else R)
            line += f"  {col}{ratio:>13.2f}x{N}"
        print(line)

    print(f"\n  {B}Duration (ms, median){N}")
    print(f"  {D}{'-' * 72}{N}")
    for t in tasks:
        line = f"  {LABELS[t]:<10s}"
        for mt in model_tags:
            line += f"  {int(agg[mt][t]['duration_ms']):>12d}"
        print(line)

# -- Render: defects heatmap ----------------------------------------------

def heat_color(v):
    if v < 1:   return G
    if v < 3:   return Y
    if v < 6:   return M
    return R

if verbose:
    print(f"\n  {B}Defect profile (mean per axis, 0=clean, 10=severe){N}")
    print(f"  {D}{'-' * 72}{N}")
    hdr = f"  {'defect':<14s}"
    for mt in model_tags: hdr += f"  {mt:>12s}"
    if len(model_tags) == 2:
        hdr += f"  {'delta':>10s}"
    print(hdr)
    for a in DEFECT_AXES:
        line = f"  {a:<14s}"
        vals = [per_model[mt]["defect_means"][a] for mt in model_tags]
        for v in vals:
            c = heat_color(v)
            line += f"  {c}{v:>12.2f}{N}"
        if len(vals) == 2:
            d = vals[0] - vals[1]
            sign = "+" if d > 0 else ""
            col = D if abs(d) < 0.5 else (R if abs(d) > 2 else Y)
            line += f"  {col}{sign}{d:>9.2f}{N}"
        print(line)

    # -- Render: per-model summary ----------------------------------------

    print(f"\n  {B}Summary{N}")
    print(f"  {D}{'-' * 72}{N}")
    for mt in model_tags:
        pm = per_model[mt]
        print(f"  {B}{mt}{N}")
        print(f"    think_tokens(mean) {pm['mean_thinking_tokens']:>8.0f}  "
              f"duration(ms) {pm['mean_duration_ms']:>7.0f}  "
              f"depth {pm['mean_depth']:>4.1f}/10  "
              f"correct {pm['mean_correctness']:>4.1f}/10")
        print(f"    shadow_pass(rate)  {pm['shadow_pass_rate']*100:>6.0f}%  "
              f"cost ${pm['total_cost']:>5.2f}")

    # -- Evidence samples (failed defects) --------------------------------

    print(f"\n  {B}Evidence samples (defects with score >= 4){N}")
    print(f"  {D}{'-' * 72}{N}")
    shown = 0
    for mt in model_tags:
        for t in tasks:
            for ev_dict in agg[mt][t]["evidence_samples"]:
                for axis, quote in ev_dict.items():
                    if quote and shown < 12:
                        q = quote.replace("\n", " ")[:80]
                        print(f"  {Y}{axis:<14s}{N} {mt:<10s} {LABELS[t]:<8s}  {D}{q}{N}")
                        shown += 1
    if shown == 0:
        print(f"  {D}(none){N}")

# -- Sonnet final analyst -------------------------------------------------

vprint(f"\n  {D}Calling Sonnet analyst for verdict...{N}")
# Strip cost/money fields - the verdict must not reference them
per_model_for_judge = {
    mt: {k: v for k, v in pm.items() if k not in ("total_cost",)}
    for mt, pm in per_model.items()
}
verdict_json = call_analyst({
    "k_runs": k_runs,
    "models": per_model_for_judge,
    "per_task": {mt: {t: {
        "thinking_tokens": agg[mt][t]["thinking_tokens"],
        "duration_ms": agg[mt][t]["duration_ms"],
        "depth": agg[mt][t]["depth"],
        "correctness": agg[mt][t]["correctness_judge"],
        "shadow_correct_rate": agg[mt][t]["shadow_correct_rate"],
        "defects": agg[mt][t]["defects"],
    } for t in tasks} for mt in model_tags},
})

print()
if verdict_json is None:
    print(gum_panel(R + "Sonnet analyst failed to produce parseable JSON" + N,
                    ["--border", "rounded", "--padding", "1 2", "--border-foreground", "196"]))
else:
    metrics_panel = render_metrics_panel(verdict_json.get("metrics", {}), model_tags)
    strengths_panel = render_strengths_panel(verdict_json.get("strengths", {}), model_tags)
    verdict_panel = render_verdict_panel(verdict_json.get("verdict", {}))
    if metrics_panel: print(metrics_panel)
    if strengths_panel: print(strengths_panel)
    if verdict_panel: print(verdict_panel)

# -- Closing note ---------------------------------------------------------

vprint(f"\n  {D}Note: bench measures CLI ({len(model_tags)*len(tasks)*k_runs} claude -p calls){N}")
vprint(f"  {D}with system prompt + plugins + MCP. Regression in CLI is attributed to model.{N}")
vprint(f"  {D}Judge: {judge_model} via Anthropic (pinned). Same judge for all targets.{N}")

# -- Save -----------------------------------------------------------------

from datetime import datetime
save = {
    "_meta": {
        "version": 3,
        "date": datetime.now().isoformat(),
        "models": models, "tasks": tasks, "k_runs": k_runs,
